# Optional overrides — sensible defaults apply if omitted.
# AUTOPILOT_REPO=/path/to/your/autopilot-repo
# NSP_STATE_DIR=/Users/you/Library/Application Support/nsp-autopilot
# PORT=4000

# Reply.io — falls back to ~/.claude.json mcpServers["reply-io"] if unset
# REPLY_IO_API_KEY=

# Lob — falls back to ~/.config/lob/credentials if unset
# LOB_API_KEY=
